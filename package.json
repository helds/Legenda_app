{
  "name": "karaoke-caption-studio",
  "version": "1.0.0",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "server": "node server/index.js",
    "client": "cd client && npm run dev",
    "electron": "electron .",
    "dev": "concurrently \"npm run client\" \"wait-on http://localhost:5173 && electron .\"",
    "build-client": "cd client && npm run build",
    "dist": "npm run build-client && electron-builder"
  },
  "dependencies": {
    "@remotion/bundler": "^4.0.0",
    "@remotion/renderer": "^4.0.0",
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "fontkit": "^2.0.4",
    "multer": "^1.4.5-lts.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "cross-env": "latest",
    "electron": "latest",
    "electron-builder": "latest",
    "wait-on": "latest"
  },
  "build": {
    "appId": "com.karaoke.caption",
    "productName": "Karaoke Caption Studio",
    "directories": {
      "output": "release"
    },
    "files": [
      "electron/**/*",
      "server/**/*",
      "shared/**/*",
      "client/dist/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis"
    }
  }
}
